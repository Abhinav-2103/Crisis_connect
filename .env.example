# CrisisConnect — Environment Variables
# Copy this file to .env and fill in your actual values
# In Vercel: go to Project → Settings → Environment Variables and add these

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your Supabase project URL (found in Supabase → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (found in Supabase → Project Settings → API)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
